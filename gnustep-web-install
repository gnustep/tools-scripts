#!/bin/sh

set -e

ROOT_DIR=$(CDPATH= cd "$(dirname "$0")" && pwd)
TOOLS_DIR="${ROOT_DIR}/tools-scripts"
ARCHIVE_URL=https://github.com/gnustep/tools-scripts/archive/refs/heads/master.tar.gz

fetch_tools_scripts()
{
    if command -v git >/dev/null 2>&1; then
        git clone https://github.com/gnustep/tools-scripts "$TOOLS_DIR"
    elif command -v curl >/dev/null 2>&1; then
        (cd "$ROOT_DIR" && curl -fsSL "$ARCHIVE_URL" | tar -xz && mv tools-scripts-master tools-scripts)
    elif command -v ftp >/dev/null 2>&1; then
        (cd "$ROOT_DIR" && ftp -o - "$ARCHIVE_URL" | tar -xz && mv tools-scripts-master tools-scripts)
    else
        echo "gnustep-web-install: need git, curl, or ftp to fetch tools-scripts" >&2
        exit 1
    fi
}

if [ -x "${ROOT_DIR}/build-gnustep" ]; then
    exec "${ROOT_DIR}/build-gnustep" --https --clone essential "$@"
fi

if [ ! -d "$TOOLS_DIR" ]; then
    fetch_tools_scripts
fi

exec "${TOOLS_DIR}/build-gnustep" --https --clone essential "$@"
